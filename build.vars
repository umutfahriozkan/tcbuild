build_silent=false
build_build_dir=build/
build_final_name="hello"
build_final_exe=clang
build_final_flags="-o \$@ \$^"

build_ext_c_exe=clang
build_ext_c_flags="-MMD -c $< -o \$@"


build_sources="test.c.x"

source bb