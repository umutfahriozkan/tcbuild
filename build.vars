# build_silent=true(default)/false
# build_build_dir=""
# build_final_name=""
# build_final_exe=""
# build_final_flags=""
# build_ext_(extension)_exe=""
# build_ext_(extension)_flags=""
# build_sources=""
#
# build_source_(name)_(extension)_out=""
# build_source_(name)_(extension)_exe=""
